# SFam Logistics — Backend environment variables
# Copy this file to .env and fill in real values on the server.

# === DATABASE (permanent storage) ===
# Neon Postgres connection string. When set, every submission, shipment, and chat
# is stored permanently. When unset, the server falls back to a local SQLite file
# (fine for local dev, but Render's free tier wipes it on restart).
# DATABASE_URL=postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/dbname?sslmode=require

# === SMTP / Email Notifications ===
# All form submissions (Quote, Carrier, Agent, Contact, Chat) are routed here.
# Hostinger SMTP example (after creating info@sfamlogistics.com mailbox):
#   SMTP_HOST=smtp.hostinger.com
#   SMTP_PORT=465  (SSL)  OR  587 (TLS)
#   SMTP_USER=info@sfamlogistics.com
#   SMTP_PASS=<the password you set in Hostinger email panel>

SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=info@sfamlogistics.com
SMTP_PASS=replace-with-mailbox-password

# "From" address shown on outgoing notifications & confirmations
SMTP_FROM=info@sfamlogistics.com

# Where every form / chat alert is delivered
ALERT_TO=info@sfamlogistics.com

# Public site URL — used inside chat alert emails to link to admin dashboard
SITE_URL=https://sfamlogistics.com

# Server port
PORT=4000
