# SFam Logistics — Backend environment variables
# Copy this file to .env and fill in real values on the server.

# === SMTP / Email Notifications ===
# All form submissions (Quote, Carrier, Agent, Contact, Subscribe, Chat) are
# routed to the right inbox per form type. Hostinger SMTP example below.

SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=info@sfamlogistics.com
SMTP_PASS=replace-with-mailbox-password

# "From" address shown on outgoing notifications & confirmations
SMTP_FROM=info@sfamlogistics.com

# === Routing rules per form type ===
# Subscribe form ("Stay Informed" newsletter) -> loads@sfamlogistics.com
ALERT_TO_LOADS=loads@sfamlogistics.com

# Contact form ("Send Us A Message") -> support@sfamlogistics.com
ALERT_TO_SUPPORT=support@sfamlogistics.com

# Quotes / Carriers / Agents / fallback -> info@sfamlogistics.com
ALERT_TO_INFO=info@sfamlogistics.com

# Legacy single-recipient fallback (used only if the type-specific vars above are not set)
ALERT_TO=info@sfamlogistics.com

# Public site URL — used inside chat alert emails to link to admin dashboard
SITE_URL=https://sfamlogistics.com

# Server port
PORT=4000
