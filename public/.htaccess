# SFam Logistics — Apache / LiteSpeed config for production hosting
# Place at the document root that serves the built React app (dist/).

# Disable content negotiation. On LiteSpeed/Hostinger this is what causes
# "No input file specified." when refreshing /about, /services, etc. —
# the server tries about.html → about.php → PHP-FPM and fails.
Options -MultiViews

RewriteEngine On
RewriteBase /

# === HTTPS REDIRECT ===
RewriteCond %{HTTPS} !=on
RewriteCond %{HTTP:X-Forwarded-Proto} !=https
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# === FORCE NON-WWW (canonical) ===
RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
RewriteRule ^ https://%1%{REQUEST_URI} [L,R=301]

# === API + UPLOADS PROXY (only enable if backend Node app sits at port 4000 on same host) ===
# RewriteCond %{REQUEST_URI} ^/(api|uploads)/
# RewriteRule ^(api|uploads)/(.*)$ http://127.0.0.1:4000/$1/$2 [P,L]

# === SPA FALLBACK ===
# Stop rewriting once we've reached index.html (prevents loops on LiteSpeed).
RewriteRule ^index\.html$ - [L]
# Anything that isn't an existing file/dir → index.html, React Router takes over.
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} !^/api/
RewriteCond %{REQUEST_URI} !^/uploads/
RewriteRule . /index.html [L]

# Force HTML response for the fallback so PHP-FPM never touches it.
<FilesMatch "\.html$">
  SetHandler default-handler
</FilesMatch>

# === SECURITY HEADERS ===
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set Permissions-Policy "camera=(), microphone=(), geolocation=()"
  Header set Strict-Transport-Security "max-age=31536000; includeSubDomains"
</IfModule>

# === COMPRESSION ===
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json application/xml application/rss+xml image/svg+xml font/ttf font/otf application/font-woff application/font-woff2
</IfModule>

# === BROWSER CACHING ===
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/jpg "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType text/html "access plus 0 seconds"
</IfModule>

# === BLOCK SENSITIVE FILES ===
<FilesMatch "(^\.|\.env|\.git|\.gitignore|package.*\.json|README\.md|\.db$|\.db-.*$|\.log$)">
  Require all denied
</FilesMatch>

# === MIME TYPES ===
<IfModule mod_mime.c>
  AddType application/javascript .js .mjs
  AddType text/css .css
  AddType image/svg+xml .svg
  AddType application/font-woff2 .woff2
  AddType image/webp .webp
</IfModule>

# === DEFAULT DOCUMENT ===
DirectoryIndex index.html
